# 이 파일은 "예시"입니다. 실제 비밀정보는 여기 적지 마세요.
#
# 클라우드(Streamlit Cloud)에 올릴 때는 이 내용을
#   앱 설정 → Settings → Secrets 화면에 붙여넣습니다.
#
# DATABASE_URL 에는 Supabase 의 Postgres 접속 주소를 넣습니다.
# (Supabase 대시보드 → Project Settings → Database → Connection string → URI)

DATABASE_URL = "postgresql://postgres:[비밀번호]@db.[프로젝트].supabase.co:5432/postgres"
